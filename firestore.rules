rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function incoming() { return request.resource.data; }

    function isValidWish(data) {
      return data.get('text', '') is string 
          && data.get('text', '').size() <= 200
          && data.get('phrase', '') is string 
          && data.get('phrase', '').size() <= 200
          && data.get('userId', '') is string
          && data.get('userId', '').size() <= 128
          && (data.get('x', 0) is number)
          && (data.get('y', 0) is number);
    }

    match /wishes/{wishId} {
      // Anyone can read/list wishes to populate the tree
      allow read: if true; 
      
      // Anyone can create a wish if it matches the strict schema
      allow create: if request.resource.data.keys().hasAll(['text', 'phrase', 'createdAt', 'userId'])
                   && request.resource.data.text is string
                   && request.resource.data.phrase is string
                   && request.resource.data.userId is string
                   && request.resource.data.createdAt == request.time;
      
      // Allow user to adjust ribbon position. 
      // We strictly limit updates to ONLY x and y fields to prevent tampering with wish content.
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['x', 'y']);

      allow delete: if false;
    }
  }
}
